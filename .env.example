# Server Configuration
# Defaults: NODE_ENV=development, PORT=4000, PUBLIC_API_URL=http://localhost:4000/api
NODE_ENV=
PORT=
PUBLIC_API_URL=

# Frontend Configuration (multiple origins separated by comma for dev/test)
FRONTEND_ORIGIN=

# Database Configuration
SQLITE_PATH=

# Admin Authentication (password will be hashed with bcrypt)
