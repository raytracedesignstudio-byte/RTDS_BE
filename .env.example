ADMIN_PASSWORD=
JWT_SECRET=
ADMIN_SESSION_TTL=

# Email Configuration (for contact form and notifications)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_TO=

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=
